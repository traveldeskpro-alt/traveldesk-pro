# Supabase Configuration (Required for cloud database + multi-tenant mode)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only key for SaaS Admin operations such as creating agency owner auth users.
# Never expose this as NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# If you leave these empty, the app runs in localStorage mode (fine for demo/testing)

# Canonical public URL used to build Supabase auth callback links
# (password reset, email verification, magic links). Defaults to
# https://traveldeskpro.app when unset. Override for local dev or staging,
# e.g. NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://traveldeskpro.app
